  "keyFeatures": [
    "Viral moment detection using Google Gemini 2.0 Flash",
    "AI-powered cropping with MediaPipe face detection and YOLOv8",
    "Automated social media posting to TikTok, Instagram, and YouTube",
    "AI voice dubbing with ElevenLabs (30+ languages)",
    "YouTube Studio with AI titles, thumbnails, and descriptions",
    "Real-time web dashboard with live progress tracking",
    "Automated S3 backup for generated clips",
    "Smart scene detection with dual-mode reframing"
  ],
  "publicApiSurface": [
    "POST /api/process - Submit video for processing",
    "GET /api/status/{job_id} - Poll job status and logs",
    "POST /api/edit - Apply AI video effects",
    "POST /api/subtitle - Generate and apply subtitles",
    "POST /api/hook - Add text hook overlays",
    "POST /api/translate - AI voice dubbing",
    "POST /api/social/post - Post to social media",
    "POST /api/thumbnail/analyze - Analyze video for titles",
    "POST /api/thumbnail/generate - Generate YouTube thumbnails",
    "POST /api/thumbnail/publish - Publish to YouTube",
    "process_video_to_vertical() - Core vertical video processing",
    "transcribe_video() - Faster-Whisper transcription",
    "get_viral_clips() - Gemini AI clip analysis",
    "SmoothedCameraman - Camera stabilization class",
    "SpeakerTracker - Active speaker tracking"
  ]
